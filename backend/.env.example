# Production template: inject real secret values via CI/CD or runtime secret management.
# DO NOT COMMIT actual secrets to version control
# Use GitHub Actions secrets, environment variables, or a secret manager for deployment

DATABASE_URL=postgresql+psycopg://__INJECT_DB_USER__:__INJECT_DB_PASSWORD__@db:5432/loanpilot
SECRET_KEY=__INJECT_AT_DEPLOY_TIME__
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=production
LOG_LEVEL=INFO
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_USERNAMES=admin,ops-admin
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=__INJECT_AT_DEPLOY_TIME__
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=__INJECT_SMTP_USER__
SMTP_PASSWORD=__INJECT_SMTP_PASSWORD__
CORS_ORIGINS=https://app.loanpilot.ai
