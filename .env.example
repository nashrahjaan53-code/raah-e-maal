# Production template: inject real secret values via CI/CD or runtime secret management.
# DO NOT COMMIT actual secrets to version control
# Use GitHub Actions secrets, environment variables, or a secret manager for deployment

# Database
POSTGRES_DB=loanpilot
POSTGRES_USER=loanpilot
POSTGRES_PASSWORD=__INJECT_AT_DEPLOY_TIME__
DATABASE_URL=postgresql+psycopg://__INJECT_DB_USER__:__INJECT_DB_PASSWORD__@db:5432/loanpilot

# Frontend
VITE_API_BASE_URL=https://api.loanpilot.ai

# Security
CORS_ORIGINS=https://app.loanpilot.ai
BACKEND_ENV_FILE=./backend/.env.production

# Logging
LOG_LEVEL=INFO
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Email (for future features)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend
VITE_API_BASE_URL=http://localhost:8000
